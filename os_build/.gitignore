# live-build generated configuration files
# All of these are regenerated by `lb config` on every build — do not commit.
config/lb/
config/common
config/binary
config/bootstrap
config/chroot
config/source
/config/hooks/normal/
config/hooks/live/
# live-build workspace (created during build, can be 10-20 GB)
cache/
chroot/
binary/
.build/

# Build log (written by build.sh, useful locally but not for git)
build.log

# Built ISO images (too large for git; retrieve from CI or build locally)
output/
*.iso
*.img

# Build artifacts generated by lb build (regenerated every build)
binary.modified_timestamps
chroot.files
chroot.packages.install
chroot.packages.live
live-image-amd64.contents
live-image-amd64.files
live-image-amd64.packages

# Build-time copies staged by build.sh (source lives at repo root os_agent/)
# The GGUF model is 2.6GB — never commit to git.
config/includes.chroot/opt/ai-daemon/os_agent/
config/includes.chroot/opt/ai-daemon/models/

# Temporary files
*~
*.tmp
