#!/bin/sh
# auto/config — live-build auto-config script.
# Called automatically by `lb config`. Calls `lb config noauto` to set all
# project-wide flags. The `noauto` keyword prevents infinite recursion.
set -e

lb config noauto \
    --distribution          "trixie" \
    --archive-areas         "main contrib non-free non-free-firmware" \
    --debootstrap-options   "--variant=minbase" \
    --binary-images         "iso-hybrid" \
    --bootappend-live       "boot=live components quiet splash" \
    --linux-flavours        "amd64" \
    --compression           "xz" \
    --apt-recommends        "false" \
    --apt-secure            "true" \
    --debian-installer      "false" \
    --memtest               "none" \
    --iso-application       "AI OS" \
    --iso-preparer          "AI OS Build System" \
    --iso-publisher         "AI OS Project" \
    "${@}"
