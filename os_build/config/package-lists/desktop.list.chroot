# desktop.list.chroot — KDE Plasma 6 desktop environment for AI OS.
# Populated in Step 3: KDE Plasma 6 Desktop.
#
# Uses kde-plasma-desktop metapackage for a complete baseline, then adds
# explicit packages that --apt-recommends false would otherwise drop.
#
# Default session: Plasma Wayland (industry direction — faster, more secure).
# X11 session available as fallback from SDDM login screen.
#
# Stripped: No KDE PIM, no games, no Konqueror, no web browser.
# Kept: Dolphin, Konsole, Spectacle, System Settings.

# ── Core desktop ─────────────────────────────────────────────────────────────
kde-plasma-desktop
sddm

# ── Display server ───────────────────────────────────────────────────────────
# plasma-desktop does NOT pull display server packages automatically.
# xserver-xorg-core: needed for X11 fallback session + XWayland
# xwayland: runs X11 apps inside Wayland session (many apps still need this)
xserver-xorg-core
xwayland

# ── Polkit (privilege escalation dialogs) ────────────────────────────────────
# polkit was split in Trixie. polkit-kde-agent-1 provides the graphical
# "enter password to perform admin action" dialog. Without it, privilege
# escalation silently fails.
polkitd
pkexec
polkit-kde-agent-1

# ── Audio (PipeWire — Trixie default) ────────────────────────────────────────
# pipewire-audio is the Debian metapackage that pulls pipewire-pulse
# (PulseAudio compat), wireplumber (session manager), and ALSA integration.
# plasma-pa (volume widget) works via the PulseAudio compatibility layer.
pipewire-audio
plasma-pa

# ── Networking GUI ───────────────────────────────────────────────────────────
# network-manager is already in base.list.chroot (backend).
# plasma-nm provides the Plasma system tray widget for WiFi/VPN management.
plasma-nm

# ── Power + Bluetooth ────────────────────────────────────────────────────────
powerdevil
bluedevil

# ── Theming ──────────────────────────────────────────────────────────────────
breeze
breeze-gtk-theme

# ── Phonon (multimedia backend) ──────────────────────────────────────────────
# Only Recommends of kde-plasma-desktop — dropped by --apt-recommends false.
# Plasma 6 uses Qt6, so the package is phonon4qt6-backend-vlc (not phonon-vlc).
phonon4qt6-backend-vlc

# ── Wayland integration ──────────────────────────────────────────────────────
xdg-desktop-portal-kde

# ── Applications ─────────────────────────────────────────────────────────────
konsole
dolphin
kde-spectacle
firefox-esr

# ── SDDM config ─────────────────────────────────────────────────────────────
kde-config-sddm

# ── Plasmoid support ────────────────────────────────────────────────────────
# Provides the QML module org.kde.plasma.plasma5support (P5Support.DataSource
# with executable engine) used by the AI assistant Plasmoid.
qml6-module-org-kde-plasma-plasma5support

# ── Standalone Settings app — Step 9 ────────────────────────────────────────
# Historical note: originally planned as a KCM (System Settings → AI
# Assistant). KF6 removed the "KCModule" KPackage structure so pure-QML KCMs
# are no longer discoverable by systemsettings — only compiled C++
# KQuickConfigModule plugins work. To keep the build pipeline declarative
# we ship a standalone Kirigami.ApplicationWindow launched from the app
# menu + plasmoid gear button instead. The scope is identical: settings
# write to ~/.config/ai-daemon/settings.yaml, read by plasmoid + neurosh.
#
# PySide6 hosts the QML engine and provides the QProcess bridge that shells
# out to aios-panel-bridge / aios-settings-write.
python3-pyside6.qtcore
python3-pyside6.qtgui
python3-pyside6.qtqml
# KWallet access is now via D-Bus (org.kde.kwalletd6) directly from the
# daemon — no need for the KF5 kwallet-query binary (which can't talk to
# the KF6 kwalletd6 service that Plasma 6 runs).

# ── Desktop notifications ──────────────────────────────────────────────────
# Used by the AI daemon to surface fallback messages on startup (e.g.
# "OpenRouter resume failed, falling back to local model").
libnotify-bin

# ── Basic CLI tools ─────────────────────────────────────────────────────────
nano
vim-tiny
less
htop
curl
wget
tree
unzip
file
man-db

# ── Essential GUI applications ──────────────────────────────────────────────
# kate: KDE text editor — richer than nano/vim-tiny for GUI editing
kate
# okular: PDF and document viewer
okular
# ark: archive manager GUI for exploring .tar, .zip, .7z, etc.
ark
# p7zip-full: 7z format support for ark and CLI usage
p7zip-full
# zip: command-line zip creation
zip
# gwenview: lightweight image viewer and organizer
gwenview

# ── Printing (CUPS with network printer auto-discovery) ──────────────────────
# cups: CUPS print daemon
cups
# cups-browsed: network printer auto-discovery — discovers CUPS printers on LAN
cups-browsed

# ── Fonts — Latin + emoji coverage ───────────────────────────────────────────
# CJK intentionally excluded to keep ISO lean; CJK users install fonts-noto-cjk on demand.
fonts-noto-core
fonts-noto-color-emoji
fonts-liberation
