#!/usr/bin/env python3
"""Settings write helper for the AI Assistant Settings app.

The Settings UI (PySide6) shells out to this script for every operation
that requires python-dbus, KWallet, or direct file I/O from the host.
Each invocation is a short-lived process that prints either "ok" or
"error: <reason>" to stdout so the Bridge can pattern-match the result.

Subcommands:
    save '<json>'                  -- overwrite ~/.config/ai-daemon/settings.yaml
                                      (deep-merged onto defaults)
    get-settings                   -- print current settings as JSON
    load <model>                   -- call org.aios.Daemon.LoadLocalModel
    unload                         -- call org.aios.Daemon.UnloadLocalModel
    reload                         -- call org.aios.Daemon.ReloadSettings
    autostart enable|disable       -- systemctl --user enable/disable
                                      ai-daemon.service
    list-profiles                  -- call ListOpenRouterProfiles -> JSON
    upsert-profile <n> <k> <m>     -- call UpsertOpenRouterProfile
    delete-profile <name>          -- call DeleteOpenRouterProfile
    set-current-profile <name>     -- call SetCurrentOpenRouterProfile
    reveal-profile <name>          -- call RevealOpenRouterKey -> plaintext
    test-openrouter <profile_name> -- call TestOpenRouterConnection (profile)
"""

from __future__ import annotations

import json
import subprocess
import sys

BUS_NAME = "org.aios.Daemon"
OBJ_PATH = "/org/aios/Daemon"
IFACE = "org.aios.Daemon"


def _ok(msg: str = "ok") -> None:
    print(msg)
    sys.exit(0)


def _err(msg: str) -> None:
    print("error: " + msg)
    sys.exit(1)


def _get_daemon():
    import dbus
    bus = dbus.SessionBus()
    proxy = bus.get_object(BUS_NAME, OBJ_PATH)
    return dbus.Interface(proxy, IFACE)


# ── save / get settings.yaml ──────────────────────────────────────────────

def cmd_save(payload: str) -> None:
    """Merge JSON payload onto current settings and write atomically."""
    try:
        data = json.loads(payload)
    except json.JSONDecodeError as e:
        _err(f"invalid json: {e}")

    try:
        sys.path.insert(0, "/opt/ai-daemon")
        from os_agent.settings import load_settings, save_settings
        merged = load_settings()
        _deep_merge_into(merged, data)
        save_settings(merged)
    except Exception as e:
        _err(str(e))
    _ok()


def cmd_get_settings() -> None:
    """Print the current merged settings as JSON (for UI hydration)."""
    try:
        sys.path.insert(0, "/opt/ai-daemon")
        from os_agent.settings import load_settings
        settings = load_settings()
        print(json.dumps(settings))
    except Exception as e:
        _err(str(e))


def _deep_merge_into(base: dict, overlay: dict) -> None:
    for k, v in (overlay or {}).items():
        if isinstance(v, dict) and isinstance(base.get(k), dict):
            _deep_merge_into(base[k], v)
        else:
            base[k] = v


# ── D-Bus passthroughs ──────────────────────────────────────────────────

def cmd_load(model_name: str) -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.LoadLocalModel(model_name))
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("load failed")


def cmd_unload() -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.UnloadLocalModel())
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("unload failed")


def cmd_reload() -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.ReloadSettings())
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("reload failed")


# ── OpenRouter profile management ─────────────────────────────────────────

def cmd_list_profiles() -> None:
    """Print profiles as JSON array (masked keys)."""
    try:
        daemon = _get_daemon()
        profiles = daemon.ListOpenRouterProfiles()
        result = []
        for p in profiles:
            result.append({str(k): _dbus_to_python(v) for k, v in p.items()})
        print(json.dumps(result))
    except Exception as e:
        _err(f"daemon unreachable: {e}")


def cmd_upsert_profile(name: str, key: str, model: str) -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.UpsertOpenRouterProfile(name, key, model))
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("upsert failed (empty name or key?)")


def cmd_delete_profile(name: str) -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.DeleteOpenRouterProfile(name))
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("delete failed (profile may be in active use)")


def cmd_set_current_profile(name: str) -> None:
    try:
        daemon = _get_daemon()
        ok = bool(daemon.SetCurrentOpenRouterProfile(name))
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    _ok() if ok else _err("set-current failed (profile not found?)")


def cmd_reveal_profile(name: str) -> None:
    """Print the plaintext key for a profile."""
    try:
        daemon = _get_daemon()
        key = str(daemon.RevealOpenRouterKey(name))
        print(key)
    except Exception as e:
        _err(f"daemon unreachable: {e}")


def cmd_test_openrouter(profile_name: str) -> None:
    """Test an OpenRouter connection using a saved profile name.

    The daemon fetches the key from KWallet internally — plaintext
    never crosses the CLI wire.
    """
    try:
        daemon = _get_daemon()
        result = daemon.TestOpenRouterConnection(profile_name, timeout=30)
        ok = bool(result[0])
        msg = str(result[1])
    except Exception as e:
        _err(f"daemon unreachable: {e}")
    if ok:
        _ok()
    else:
        _err(msg or "connection failed")


# ── systemd --user autostart ────────────────────────────────────────────

def cmd_autostart(action: str) -> None:
    if action not in ("enable", "disable"):
        _err("autostart: expected 'enable' or 'disable'")
    try:
        result = subprocess.run(
            ["systemctl", "--user", action, "ai-daemon.service"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            _err(result.stderr.strip() or f"systemctl {action} failed")
    except FileNotFoundError:
        _err("systemctl not available")
    _ok()


# ── Helpers ─────────────────────────────────────────────────────────────

def _dbus_to_python(v):
    """Convert a dbus variant to a plain Python type for JSON serialization."""
    import dbus
    if isinstance(v, dbus.Boolean):
        return bool(v)
    if isinstance(v, (dbus.UInt32, dbus.Int32, dbus.Int64, dbus.UInt64)):
        return int(v)
    if isinstance(v, dbus.Double):
        return float(v)
    return str(v)


# ── dispatch ────────────────────────────────────────────────────────────

def main() -> None:
    if len(sys.argv) < 2:
        _err("usage: aios-settings-write <command> [args]")
    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "save" and args:
        cmd_save(args[0])
    elif cmd == "get-settings":
        cmd_get_settings()
    elif cmd == "load" and args:
        cmd_load(args[0])
    elif cmd == "unload":
        cmd_unload()
    elif cmd == "reload":
        cmd_reload()
    elif cmd == "list-profiles":
        cmd_list_profiles()
    elif cmd == "upsert-profile" and len(args) >= 3:
        cmd_upsert_profile(args[0], args[1], args[2])
    elif cmd == "delete-profile" and args:
        cmd_delete_profile(args[0])
    elif cmd == "set-current-profile" and args:
        cmd_set_current_profile(args[0])
    elif cmd == "reveal-profile" and args:
        cmd_reveal_profile(args[0])
    elif cmd == "test-openrouter" and args:
        cmd_test_openrouter(args[0])
    elif cmd == "autostart" and args:
        cmd_autostart(args[0])
    else:
        _err(f"unknown or incomplete command: {cmd}")


if __name__ == "__main__":
    main()
